# ===== Flask =====
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True
SECRET_KEY=change-me-use-a-long-random-string

# ===== Database =====
DATABASE_URL=sqlite:///wifi_billing.db

# ===== PesaPal =====
PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CALLBACK_URL=https://your-ngrok-url.ngrok.io/webhook/pesapal/callback
PESAPAL_IPN_URL=https://your-ngrok-url.ngrok.io/webhook/pesapal

# ===== Router (ZLT X17U via SSH) =====
ROUTER_HOST=192.168.1.1
ROUTER_SSH_USER=admin
ROUTER_SSH_PASSWORD=your_router_password_here
ROUTER_SSH_PORT=22
ROUTER_SSH_TIMEOUT=10

# ===== WiFi Packages =====
WIFI_PACKAGE_1_NAME=Basic (1 Hour)
WIFI_PACKAGE_1_DURATION=3600
WIFI_PACKAGE_1_PRICE=50
WIFI_PACKAGE_2_NAME=Standard (1 Day)
WIFI_PACKAGE_2_DURATION=86400
WIFI_PACKAGE_2_PRICE=100
WIFI_PACKAGE_3_NAME=Premium (7 Days)
WIFI_PACKAGE_3_DURATION=604800
WIFI_PACKAGE_3_PRICE=300

# ===== Admin =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_123
ADMIN_EMAIL=admin@yourdomain.com

# ===== Security =====
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRATION_HOURS=24
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ===== Payment =====
PAYMENT_TIMEOUT_MINUTES=5
MAX_PAYMENT_AMOUNT=10000
MIN_PAYMENT_AMOUNT=10

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ===== Sessions =====
SESSION_TIMEOUT_MINUTES=1440
REMEMBER_ME_DAYS=7

# ===== SMS (Africa's Talking) =====
SEND_SMS_NOTIFICATIONS=True
AFRICASTALKING_API_KEY=your_key_here
AFRICASTALKING_USERNAME=your_username_here

# ===== ngrok =====
NGROK_AUTH_TOKEN=your_ngrok_token_here
NGROK_REGION=sa
